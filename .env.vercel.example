# Environment Variables untuk Vercel (Frontend Vite)
# Isi di Vercel -> Project Settings -> Environment Variables
# Gunakan milik project Neon Anda sendiri, jangan hardcode milik project lain.

VITE_DATABASE_URL=postgres://YOUR_USER:YOUR_PASSWORD@ep-XXXXX.REGION.aws.neon.tech/neondb?sslmode=require
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
