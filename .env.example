# =============================================================
# Environment Variables untuk MA Amanatulloh Website
# =============================================================
# Copy file ini menjadi .env dan isi dengan value yang benar
# JANGAN commit file .env ke Git!
# =============================================================

# Neon Database Configuration
# Dapatkan dari: Neon Dashboard → Project Settings → Connection Details
# Gunakan connection string dari tab "Pooled" atau "Direct"
# Format: postgres://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require
VITE_DATABASE_URL=postgres://YOUR_USER:YOUR_PASSWORD@ep-XXXXX.REGION.aws.neon.tech/neondb?sslmode=require

# Google Analytics (Opsional)
# Dapatkan dari: Google Analytics → Admin → Data Streams → Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
